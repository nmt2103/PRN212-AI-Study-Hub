<Window x:Class="Prn212.AIStudyHub.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF"
        mc:Ignorable="d"
        Title="AI Study Hub - Trang Chủ" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource BackgroundBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          
            <TextBlock Text="Chào Mừng Bạn Đến Với AI Study Hub" 
                       Style="{StaticResource HeaderTextBlockStyle}"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
          
            <TextBlock Text="Nơi quản lý tài liệu học tập thông minh và dễ dàng." 
                       Style="{StaticResource DescriptionTextBlockStyle}"
                       Margin="0,0,0,30"/>
            
            <Button x:Name="btnOpenUpload" Content="Đăng Tải Tài Liệu" 
                    Style="{StaticResource ModernButtonStyle}"
                    Width="150" Height="45"
                    Click="BtnOpenUpload_Click"/>
        </StackPanel>
    </Grid>
</Window>
