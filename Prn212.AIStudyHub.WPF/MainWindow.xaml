<Window x:Class="Prn212.AIStudyHub.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF"
        Title="AI Study Hub - Trang Chủ" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Thanh tiêu đề -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="20,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AI Study Hub" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Hệ thống quản lý tài liệu học tập" FontSize="14" Foreground="{StaticResource TextLightMutedBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtWelcome" Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="SemiBold" FontSize="14"/>

                    <!-- Nút Profile -->
                    <Border BorderThickness="1.5" BorderBrush="{StaticResource BorderLightBrush}" CornerRadius="18" Background="{StaticResource SecondaryBrush}">
                        <Button x:Name="btnProfile" Click="btnProfile_Click" Width="110" Height="36" TabIndex="6"
                                Style="{StaticResource RoundedButtonStyle}" Background="Transparent" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" Foreground="White" FontSize="14"/>
                                <TextBlock x:Name="txtProfileButtonText" Text=" Hồ sơ" Foreground="White" FontWeight="SemiBold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Popup Menu cho Profile -->
        <Popup Name="ProfilePopup" PlacementTarget="{Binding ElementName=btnProfile}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel Width="180">
                    <TextBlock x:Name="txtProfileName" Text="User" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="txtProfileEmail" Text="user@gmail.com" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,16"/>

                    <Button Name="btnUpdateProfile" Content="Hồ sơ của tôi" Margin="0,0,0,6" Click="btnUpdateProfile_Click" Style="{StaticResource ButtonPopupStyle}"/>
                    <Button Content="Đổi mật khẩu" Margin="0,0,0,6" Style="{StaticResource ButtonPopupStyle}"/>
                    <Separator Margin="0,6" Background="#E5E7EB"/>
                    <Button Content="Đăng xuất" Margin="0,6,0,0" Click="BtnLogout_Click" Style="{StaticResource ButtonPopupStyle}" Foreground="#EF4444"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 2. Thanh công cụ -->
        <Border Grid.Row="1" Background="White" Margin="20,20,20,10" Padding="16" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 1. Tìm kiếm -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <!-- Ô nhập liệu chính -->
                    <TextBox x:Name="txtSearch" Height="40" TabIndex="1"
                             Style="{StaticResource ModernTextBoxStyle}"
                             KeyDown="TxtSearch_KeyDown" TextChanged="TxtSearch_TextChanged"
                             Padding="36,0,12,0" FontSize="14" VerticalContentAlignment="Center"/>

                    <TextBlock Text="🔍" Foreground="#9CA3AF" FontSize="15" 
                               VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>

                    <!-- Placeholder -->
                    <TextBlock Text="Tìm kiếm tài liệu..." Foreground="#9CA3AF" FontSize="14" 
                               VerticalAlignment="Center" Margin="38,0,10,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearch}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- 2. Các ComboBox Bộ lọc -->
                <ComboBox x:Name="cbSubjectFilter" Grid.Column="1" Width="180" Height="40" Margin="0,0,12,0" TabIndex="2"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="Filter_Changed"
                          Style="{StaticResource PillComboBoxStyle}"/>

                <ComboBox x:Name="cbSort" Grid.Column="2" Width="160" Height="40" VerticalAlignment="Center" Margin="0,0,16,0" TabIndex="3"
                          SelectionChanged="Filter_Changed"
                          Style="{StaticResource PillComboBoxStyle}">
                    <ComboBoxItem Content="Mới nhất" Tag="date" IsSelected="True"/>
                    <ComboBoxItem Content="Tên (A-Z)" Tag="name"/>
                    <ComboBoxItem Content="Dung lượng" Tag="size"/>
                </ComboBox>

                <!-- 3. Nút Tải Lên -->
                <Button x:Name="btnUpload" Grid.Column="3" Width="130" Height="40" Click="BtnUpload_Click" TabIndex="4"
                        Style="{StaticResource SuccessButtonStyle}" Padding="16,0" 
                        Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤" Margin="0,0,8,0" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Tải Lên" FontWeight="Bold" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 3. Danh sách tài liệu -->
        <Border Grid.Row="2" Background="White" Margin="20,0,20,16" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <DataGrid x:Name="dgDocuments" Margin="0" BorderThickness="0" TabIndex="5"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                          RowHeight="45" FontSize="14" Background="Transparent"
                          AlternatingRowBackground="#FAFAFA"
                          MouseDoubleClick="DgDocuments_MouseDoubleClick">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Padding" Value="12,14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu Opened="ContextMenu_Opened">
                            <MenuItem Header="Xem chi tiết" Click="BtnOpenDetail_Click" Padding="10,5"/>
                            <MenuItem Header="Xem trước" Click="MenuItemPreview_Click" Padding="10,5"/>
                            <MenuItem Header="Tải xuống" Click="MenuItemDownload_Click" Padding="10,5"/>
                            <Separator/>
                            <MenuItem Header="Chỉnh sửa" Click="BtnOpenEdit_Click" Padding="10,5"/>
                            <MenuItem Header="Xóa" Click="MenuItemDelete_Click" Padding="10,5" Foreground="#EF4444"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tiêu đề" Binding="{Binding Title}" Width="2.5*"/>
                        <DataGridTemplateColumn Header="Môn học" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" 
                                            Padding="10,4" 
                                            HorizontalAlignment="Left" 
                                            VerticalAlignment="Center" 
                                            Background="#EFF6FF">
                                        <TextBlock Text="{Binding Subject.Name}" 
                                                    Foreground="#2563EB" 
                                                    FontWeight="SemiBold" 
                                                    FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tên tệp" Binding="{Binding FileName}" Width="2*"/>
                        <DataGridTemplateColumn Header="Loại" Width="0.8*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeBorder" 
                    CornerRadius="4" 
                    Padding="10,4" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" 
                    Background="#9CA3AF">
                                        <TextBlock Text="{Binding FileExtension}" 
                           Foreground="White" 
                           FontWeight="Bold" 
                           FontSize="13"/>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding FileExtension}" Value=".docx">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#3B82F6"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding FileExtension}" Value=".pdf">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#EF4444"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding FileExtension}" Value=".zip">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#10B981"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding FileExtension}" Value=".xlsx">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#16A34A"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Dung lượng" Binding="{Binding FileSize, StringFormat={}{0:N0} bytes}" Width="130"/>
                        <DataGridTextColumn Header="Ngày tải" Binding="{Binding UploadedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="tbEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="📭" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Không có tài liệu nào để hiển thị" FontSize="18" FontWeight="SemiBold" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Hãy thử thay đổi bộ lọc môn học hoặc tải lên tài liệu mới." FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. Thanh trạng thái -->
        <Border Grid.Row="3" Background="#FFFFFF" Padding="20,12" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <TextBlock x:Name="txtStatus" Style="{StaticResource HintTextBlockStyle}" FontSize="13" Foreground="#6B7280"/>
        </Border>
    </Grid>
</Window>