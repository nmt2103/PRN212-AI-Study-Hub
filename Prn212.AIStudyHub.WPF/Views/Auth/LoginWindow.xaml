<Window x:Class="Prn212.AIStudyHub.WPF.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Study Hub - Đăng nhập" Height="560" Width="430"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#EEF2F7">
    <Grid>
        <Border Background="White" CornerRadius="14" Width="350" Padding="30,34"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.14"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="AI Study Hub" FontSize="27" FontWeight="Bold"
                           Foreground="#1E3A8A" HorizontalAlignment="Center"/>
                <TextBlock Text="Đăng nhập để tiếp tục" FontSize="13" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,4,0,26"/>

                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Height="38" VerticalContentAlignment="Center"
                         Padding="10,0" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Foreground="#374151" Margin="0,16,0,5"/>
                <PasswordBox x:Name="pwdPassword" Height="38" VerticalContentAlignment="Center"
                             Padding="10,0" BorderBrush="#D1D5DB" KeyDown="Pwd_KeyDown"/>

                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12"
                           TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>

                <Button x:Name="btnLogin" Content="Đăng nhập" Height="42" Margin="0,22,0,0"
                        Background="#3B82F6" Foreground="White" FontSize="15" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Chưa có tài khoản? " Foreground="#6B7280"/>
                    <TextBlock x:Name="lnkRegister" Text="Đăng ký ngay" Foreground="#3B82F6"
                               FontWeight="SemiBold" Cursor="Hand" MouseLeftButtonUp="LnkRegister_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
