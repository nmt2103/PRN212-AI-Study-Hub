<Window x:Class="Prn212.AIStudyHub.WPF.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Study Hub - Đăng Nhập" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="24" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="28,32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.08"/>
        </Border.Effect>
        <StackPanel>
            <!-- Logo / Brand Header -->
            <TextBlock Text="🎓 AI Study Hub" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Đăng nhập tài khoản để tiếp tục" FontSize="13" 
                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,6,0,24"/>

            <!-- Form Fields -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Địa chỉ Email (*):" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBoxStyle}" Height="38" TabIndex="1"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Mật khẩu (*):" Style="{StaticResource FormLabelStyle}"/>
                <PasswordBox x:Name="pwdPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="2"
                             KeyDown="Pwd_KeyDown"/>
            </StackPanel>

            <!-- Error message container -->
            <TextBlock x:Name="txtError" Foreground="{StaticResource DangerBrush}" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

            <!-- Login Submit Button -->
            <Button x:Name="btnLogin" Content="Đăng Nhập" Height="42" TabIndex="3"
                    Style="{StaticResource ModernButtonStyle}" FontSize="15" Click="BtnLogin_Click"/>

            <!-- Register Link -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                <TextBlock Text="Chưa có tài khoản? " Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock x:Name="lnkRegister" Text="Đăng ký ngay" Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="SemiBold" Cursor="Hand" MouseLeftButtonUp="LnkRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
