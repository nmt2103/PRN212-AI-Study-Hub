<Window x:Class="Prn212.AIStudyHub.WPF.Views.Auth.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Study Hub - Đăng ký" Height="640" Width="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#EEF2F7">
    <Grid>
        <Border Background="White" CornerRadius="14" Width="350" Padding="30,28"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.14"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Tạo tài khoản mới" FontSize="22" FontWeight="Bold"
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,22"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Họ" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtLastName" Height="36" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tên" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFirstName" Height="36" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#374151" Margin="0,14,0,5"/>
                <TextBox x:Name="txtEmail" Height="36" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Foreground="#374151" Margin="0,14,0,5"/>
                <PasswordBox x:Name="pwdPassword" Height="36" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Xác nhận mật khẩu" FontWeight="SemiBold" Foreground="#374151" Margin="0,14,0,5"/>
                <PasswordBox x:Name="pwdConfirm" Height="36" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB"/>

                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12"
                           TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>

                <Button x:Name="btnRegister" Content="Đăng ký" Height="42" Margin="0,20,0,0"
                        Background="#10B981" Foreground="White" FontSize="15" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="BtnRegister_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                    <TextBlock Text="Đã có tài khoản? " Foreground="#6B7280"/>
                    <TextBlock x:Name="lnkBack" Text="Quay lại đăng nhập" Foreground="#3B82F6"
                               FontWeight="SemiBold" Cursor="Hand" MouseLeftButtonUp="LnkBack_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
