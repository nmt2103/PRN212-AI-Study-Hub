<Window x:Class="Prn212.AIStudyHub.WPF.Views.Auth.ManageUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Người Dùng" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Thanh tiêu đề -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="20,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🛡️" FontSize="22" Margin="0,0,10,0"/>
                <TextBlock Text="Quản Lý Người Dùng" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Danh sách Sinh viên" FontSize="14" Foreground="{StaticResource TextLightMutedBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 2. Danh sách người dùng -->
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            
            <DataGrid x:Name="dgUsers" Margin="0" BorderThickness="0" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                      RowHeight="50" FontSize="14" Background="Transparent"
                      AlternatingRowBackground="#FAFAFA">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Padding" Value="12,14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Họ và tên" Width="2*">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="LastName" />
                                <Binding Path="FirstName" />
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                    
                    <DataGridTextColumn Header="Ngày tham gia" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="Trạng thái" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBorder" Style="{StaticResource ManageUsersStatusBorderStyle}">
                                    <TextBlock x:Name="StatusText" Style="{StaticResource ManageUsersStatusTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Thao tác" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="BtnToggleStatus_Click" Style="{StaticResource ManageUserToggleButtonStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
