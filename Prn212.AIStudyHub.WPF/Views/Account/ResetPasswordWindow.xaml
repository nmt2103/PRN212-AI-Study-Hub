<Window x:Class="Prn212.AIStudyHub.WPF.Views.Account.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF.Views.Account"
        mc:Ignorable="d"
        Title="ResetPasswordWindow" Height="607" Width="800"
        WindowStartupLocation="CenterOwner"
        >
    <Border Margin="24" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="28,32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.08"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Right" Width="653" Canvas.Left="33" Canvas.Top="58">
            <Button Name="btnBack"  Foreground="White"  Width="100" Height="33"  HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource ModernButtonStyle}"
                     Click="btnBack_Click"
                     >
                <TextBlock Text="Trở về" Foreground="White" ></TextBlock>
            </Button>
            <!-- Logo / Brand Header -->
                <TextBlock Text="🎓 AI Study Hub" FontSize="26" FontWeight="Bold"
             Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Name="txtEmail" FontSize="13" 
             Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,6,0,24"/>

                <!-- Form Fields -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Nhập mật khẩu hiện tại" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="txtCurrentPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="2" />
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Nhập mật khẩu mới:" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="pwNewPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="2"
                   />
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Xác nhận mật khẩu:" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="pwConfirm" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="2"
                   />
                </StackPanel>

                <TextBlock x:Name="txtError" Foreground="{StaticResource DangerBrush}" FontSize="12"
             TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>
                <Button x:Name="btnChangePassword" Height="42" TabIndex="3"
                    Style="{StaticResource ModernButtonStyle}" Click="btnChangePassword_click">
                    <TextBlock Text="Xác nhận đổi mật khẩu" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>
    </Border>
</Window>
