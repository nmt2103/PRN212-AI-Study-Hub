<Window x:Class="Prn212.AIStudyHub.WPF.Views.Account.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi Mật Khẩu" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Margin="16" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.08"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <!-- Lock icon -->
                <Border Width="72" Height="72" CornerRadius="36" Background="{StaticResource PrimaryBrush}" 
                        HorizontalAlignment="Center" Margin="0,10,0,12">
                    <TextBlock Text="🔒" FontSize="32" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title & Subtitle -->
                <TextBlock Text="Đổi Mật Khẩu" FontSize="18" FontWeight="Bold" 
                           Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtEmail" FontSize="13" 
                           Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>

                <Separator Margin="0,12,0,0" Background="#E5E7EB"/>
            </StackPanel>

            <!-- 2. Form Fields -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Mật khẩu hiện tại:" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="txtCurrentPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="1"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Mật khẩu mới:" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="pwNewPassword" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="2"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Xác nhận mật khẩu mới:" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="pwConfirm" Style="{StaticResource ModernPasswordBoxStyle}" Height="38" TabIndex="3"/>
                </StackPanel>

                <TextBlock x:Name="txtError" Foreground="{StaticResource DangerBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>
            </StackPanel>

            <!-- 3. Action Buttons -->
            <Grid Grid.Row="2" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnBack" Grid.Column="0" Margin="0,0,6,0" Click="btnBack_Click" TabIndex="5"
                        Style="{StaticResource ModernButtonStyle}">
                    <TextBlock Text="Quay Lại" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="btnChangePassword" Grid.Column="1" Margin="6,0,0,0" Click="btnChangePassword_click" TabIndex="4"
                        Style="{StaticResource SuccessButtonStyle}">
                    <TextBlock Text="Xác Nhận" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
