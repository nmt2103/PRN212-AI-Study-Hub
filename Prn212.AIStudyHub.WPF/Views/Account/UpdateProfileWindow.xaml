<Window x:Class="Prn212.AIStudyHub.WPF.Views.Account.UpdateProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF.Views.Account"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="Thông Tin Tài Khoản" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="16" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.08"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Header & User Profile Visual -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <!-- Avatar circle -->
                <Border Width="72" Height="72" CornerRadius="36" Background="{StaticResource AvatarBrush}" 
                        HorizontalAlignment="Center" Margin="0,10,0,12">
                    <TextBlock Text="👤" FontSize="32" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Full name & Role -->
                <TextBlock x:Name="txtFullName" Text="Tên Người Dùng" FontSize="18" FontWeight="Bold" 
                           Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Thành viên AI Study Hub" FontSize="13" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                
                <Separator Margin="0,12,0,0" Background="#E5E7EB"/>
            </StackPanel>

            <!-- 2. Form Nhập Liệu -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Địa chỉ Email:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBoxStyle}" Height="38"
                             IsReadOnly="True" Focusable="False"/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tên (*):" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox x:Name="txtFirstName" Style="{StaticResource ModernTextBoxStyle}" Height="38" TabIndex="1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Họ (*):" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox x:Name="txtLastName" Style="{StaticResource ModernTextBoxStyle}" Height="38" TabIndex="2"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Ngày tham gia:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtCreatedAt" Style="{StaticResource ModernTextBoxStyle}" Height="38"
                             IsReadOnly="True" Focusable="False"/>
                </StackPanel>
            </StackPanel>

            <!-- 3. Nút Hành Động -->
            <Grid Grid.Row="2" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnBack" Grid.Column="0" Margin="0,0,6,0" Click="btnBack_click" TabIndex="4"
                        Style="{StaticResource ModernButtonStyle}">
                    <TextBlock Text="Quay Lại" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="btnUpdateProfile" Grid.Column="1" Margin="6,0,0,0" Click="btnUpdateProfile_Click" TabIndex="3"
                        Style="{StaticResource SuccessButtonStyle}">
                    <TextBlock Text="Lưu Thay Đổi" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
