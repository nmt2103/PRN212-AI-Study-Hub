<Window x:Class="Prn212.AIStudyHub.WPF.Views.Documents.DownloadDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tải Xuống Tài Liệu" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tải Xuống Tài Liệu Học Tập" 
                   Style="{StaticResource SubHeaderTextBlockStyle}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="Chọn tài liệu muốn tải về (*):" Style="{StaticResource FormLabelStyle}"/>
            <ComboBox x:Name="cbDocuments" Height="34" Margin="0,0,0,15"
                      DisplayMemberPath="Title" SelectedValuePath="Id"
                      Style="{StaticResource ModernComboBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" x:Name="spProgress" Visibility="Collapsed" Margin="0,0,0,15">
            <TextBlock x:Name="txtStatus" Text="Đang tải xuống..." Style="{StaticResource HintTextBlockStyle}" Margin="0,0,0,5"/>
            <ProgressBar x:Name="pbProgress" Style="{StaticResource ModernProgressBarStyle}"/>
        </StackPanel>

        <UniformGrid Grid.Row="3" Columns="2" Rows="1" Height="38">
            <Button x:Name="btnDownload" Content="Tải Về" Margin="0,0,10,0" Click="BtnDownload_Click"
                    Style="{StaticResource SuccessButtonStyle}"/>
            <Button x:Name="btnCancel" Content="Đóng" Margin="10,0,0,0" Click="BtnCancel_Click"
                    Style="{StaticResource DangerButtonStyle}"/>
        </UniformGrid>
    </Grid>
</Window>
