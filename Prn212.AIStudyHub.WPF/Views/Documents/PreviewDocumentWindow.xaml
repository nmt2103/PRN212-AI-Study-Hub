<Window x:Class="Prn212.AIStudyHub.WPF.Views.Documents.PreviewDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xem Trước Tài Liệu" Height="700" Width="950"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Thanh Tiêu Đề Tài Liệu Phía Trên -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon tệp tin -->
                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="8" Background="#F3F4F6" Margin="0,0,12,0">
                    <TextBlock x:Name="txtFileIcon" Text="📄" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Metadata tiêu đề -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="lblDocTitle" Text="Tên Tài Liệu Đang Xem" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="lblDocMeta" Text="Định dạng tệp • Dung lượng" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnDownload" Width="110" Height="34" Margin="0,0,8,0" Click="BtnDownload_Click"
                            Style="{StaticResource SuccessButtonStyle}">
                        <TextBlock Text="⬇ Tải Xuống" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Button>
                    <Button x:Name="btnClose" Width="120" Height="34" Click="BtnClose_Click"
                            Style="{StaticResource DangerButtonStyle}">
                        <TextBlock Text="Đóng" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Vùng Hiển Thị Nội Dung -->
        <Grid Grid.Row="1" Margin="20">
            <!-- Trình xem PDF (Full Width) -->
            <Border x:Name="pdfBorder" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.06"/>
                </Border.Effect>
                <WebBrowser x:Name="pdfViewer"/>
            </Border>

            <!-- Trình xem Văn bản (Căn giữa dạng Trang giấy nổi 800px) -->
            <Border x:Name="textViewerContainer" MaxWidth="800" HorizontalAlignment="Center" 
                    Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" ClipToBounds="True" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.08"/>
                </Border.Effect>
                <FlowDocumentScrollViewer x:Name="textViewer" VerticalScrollBarVisibility="Auto" 
                                          HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument x:Name="flowDoc" PagePadding="48,36" Background="White" FontFamily="Segoe UI" FontSize="15" LineHeight="24" Foreground="#1F2937">
                        <Paragraph>
                            <Run x:Name="runContent" Text="Đang tải nội dung..."/>
                        </Paragraph>
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </Border>

            <!-- Vùng Báo Lỗi -->
            <Border x:Name="errorPanel" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="32" 
                    MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚠️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Name="lblErrorMessage" Text="Không thể xem định dạng tài liệu này trực tiếp." 
                               Foreground="{StaticResource DangerBrush}" FontSize="15" FontWeight="SemiBold"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
