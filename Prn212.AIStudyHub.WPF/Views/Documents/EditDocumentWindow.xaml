<Window x:Class="Prn212.AIStudyHub.WPF.Views.Documents.EditDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh Sửa Tài Liệu" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="16" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.08"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Tiêu đề -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Chỉnh Sửa Thông Tin" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Separator Margin="0,10,0,0" Background="#E5E7EB"/>
            </StackPanel>

            <!-- 2. Form Nhập Liệu -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <StackPanel x:Name="spDocSelection" Margin="0,0,0,12">
                    <TextBlock Text="Chọn tài liệu muốn chỉnh sửa (*):" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="cbDocuments" Height="38" TabIndex="1"
                              DisplayMemberPath="Title" SelectedValuePath="Id"
                              SelectionChanged="CbDocuments_SelectionChanged"
                              Style="{StaticResource PillComboBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Tiêu đề tài liệu (*):" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBoxStyle}" Height="38" TabIndex="2"
                             TextChanged="TxtTitle_TextChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Chọn môn học (*):" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="cbSubject" Height="38" TabIndex="3"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="CbSubject_SelectionChanged"
                              Style="{StaticResource PillComboBoxStyle}"/>
                </StackPanel>
            </StackPanel>

            <!-- 3. Nút Hành Động -->
            <Grid Grid.Row="2" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSave" Grid.Column="0" Margin="0,0,6,0" Click="BtnSave_Click" TabIndex="4"
                        Style="{StaticResource SuccessButtonStyle}">
                    <TextBlock Text="Lưu Thay Đổi" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="btnCancel" Grid.Column="1" Margin="6,0,0,0" Click="BtnCancel_Click" TabIndex="5"
                        Style="{StaticResource DangerButtonStyle}">
                    <TextBlock Text="Hủy Bỏ" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
