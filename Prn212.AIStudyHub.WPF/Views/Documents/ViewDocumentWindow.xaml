<Window x:Class="Prn212.AIStudyHub.WPF.Views.Documents.ViewDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Tài Liệu" Width="720" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- File preview & Tác vụ chính -->
        <Border Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.06"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Icon tệp tin -->
                <TextBlock x:Name="txtFileIcon" Grid.Row="0" Text="📁" FontSize="72" HorizontalAlignment="Center" Margin="0,10,0,12"/>

                <!-- Tiêu đề và định dạng -->
                <TextBlock x:Name="txtTitle" Grid.Row="1" Text="Tên Tài Liệu" FontSize="16" FontWeight="Bold" 
                           Foreground="{StaticResource SecondaryBrush}" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="60" Margin="0,0,0,6"/>

                <TextBlock x:Name="txtFileSize" Grid.Row="2" Text="0 KB" FontSize="13" 
                           Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" Margin="0,0,0,20"/>

                <!-- Các Nút Tác Vụ Dọc -->
                <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
                    <Button x:Name="btnDownload" Content="⬇ Tải Xuống" Height="38" Margin="0,0,0,10" 
                            Click="BtnDownload_Click" Style="{StaticResource SuccessButtonStyle}" IsEnabled="False"/>
                    <Button x:Name="btnEdit" Content="✏ Chỉnh Sửa" Height="38" Margin="0,0,0,10" 
                            Click="BtnEdit_Click" Style="{StaticResource ModernButtonStyle}" IsEnabled="False"/>
                    <Button x:Name="btnDelete" Content="🗑 Xóa Tài Liệu" Height="38" 
                            Click="BtnDelete_Click" Style="{StaticResource DangerButtonStyle}" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chi tiết thông số -->
        <Border Grid.Column="1" Margin="20,0,0,0" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.06"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Thông Tin Chi Tiết" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,12"/>
                <Separator Grid.Row="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Môn học -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Môn học:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtSubject" Grid.Column="1" Text="N/A" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                        <Separator Background="#F3F4F6"/>

                        <!-- Tác giả -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Người tải lên:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtAuthor" Grid.Column="1" Text="N/A" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                        <Separator Background="#F3F4F6"/>

                        <!-- Ngày đăng -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ngày tải lên:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtUploadedDate" Grid.Column="1" Text="N/A" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="#F3F4F6"/>

                        <!-- Tên file gốc -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tên tệp gốc:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtFileName" Grid.Column="1" Text="N/A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Separator Background="#F3F4F6"/>

                        <!-- Loại tệp -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Loại tệp:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtFileExtension" Grid.Column="1" Text="N/A" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="#F3F4F6"/>

                        <!-- Content Type -->
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Loại nội dung:" FontWeight="SemiBold" Foreground="{StaticResource FormLabelBrush}"/>
                            <TextBlock x:Name="txtContentType" Grid.Column="1" Text="N/A" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
