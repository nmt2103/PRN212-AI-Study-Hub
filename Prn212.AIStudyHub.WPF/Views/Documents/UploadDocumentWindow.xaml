<Window x:Class="Prn212.AIStudyHub.WPF.Views.UploadDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF.Views"
        mc:Ignorable="d"
        Title="Tải Lên Tài Liệu Mới" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="16" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.08"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Tiêu đề -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Tải Lên Tài Liệu" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Separator Margin="0,10,0,0" Background="#E5E7EB"/>
            </StackPanel>

            <!-- 2. Form Nhập Liệu -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Tiêu đề tài liệu (*):" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBoxStyle}" Height="38" TabIndex="1"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Chọn môn học (*):" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="cbSubject" Style="{StaticResource PillComboBoxStyle}" Height="38" TabIndex="2"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Người tải lên:" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtUserDisplayName" Style="{StaticResource ModernTextBoxStyle}" Height="38"
                             IsReadOnly="True" Focusable="False"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Chọn tệp tin tài liệu (*):" Style="{StaticResource FormLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnBrowse" Grid.Column="0" Content="Chọn tệp" 
                                Style="{StaticResource ModernButtonStyle}" TabIndex="3"
                                Width="100" Height="38" Click="BtnBrowse_Click"/>
                        <TextBlock x:Name="lblFileName" Grid.Column="1" 
                                   Text="Chưa chọn tệp (.pdf, .docx, .xlsx, .pptx, .txt, .md)" 
                                   Style="{StaticResource HintTextBlockStyle}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- 3. Tiến trình tải lên -->
            <StackPanel Grid.Row="2" x:Name="spProgress" Visibility="Collapsed" Margin="0,0,0,16">
                <TextBlock Text="Đang xử lý tải lên..." Style="{StaticResource HintTextBlockStyle}" Margin="0,0,0,6"/>
                <ProgressBar x:Name="pbUpload" Style="{StaticResource ModernProgressBarStyle}" Height="6" IsIndeterminate="True"/>
            </StackPanel>

            <!-- 4. Nút Hành Động -->
            <Grid Grid.Row="3" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnUpload" Grid.Column="0" Content="Tải Lên" Margin="0,0,6,0" Click="BtnUpload_Click" TabIndex="4"
                        Style="{StaticResource SuccessButtonStyle}"/>
                <Button x:Name="btnCancel" Grid.Column="1" Content="Hủy Bỏ" Margin="6,0,0,0" Click="BtnCancel_Click" TabIndex="5"
                        Style="{StaticResource DangerButtonStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
