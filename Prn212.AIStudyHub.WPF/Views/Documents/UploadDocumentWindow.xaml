<Window x:Class="Prn212.AIStudyHub.WPF.Views.UploadDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF.Views"
        mc:Ignorable="d"
        Title="Upload Tài Liệu Mới" Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Đăng Tải Tài Liệu Học Tập" 
                   Style="{StaticResource SubHeaderTextBlockStyle}"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            
            <TextBlock Text="Tiêu đề tài liệu (*):" Style="{StaticResource FormLabelStyle}"/>
            <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

            <TextBlock Text="Chọn môn học (*):" Style="{StaticResource FormLabelStyle}"/>
            <ComboBox x:Name="cbSubject" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,0,15"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Người tải lên:" Style="{StaticResource FormLabelStyle}"/>
            <TextBox x:Name="txtUserDisplayName" Style="{StaticResource ModernTextBoxStyle}" 
                     Margin="0,0,0,15" IsReadOnly="True" Focusable="False"/>

            <TextBlock Text="Chọn tệp tin tài liệu (*):" Style="{StaticResource FormLabelStyle}"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnBrowse" Grid.Column="0" Content="Chọn tệp" 
                        Style="{StaticResource ModernButtonStyle}"
                        Width="100" Height="34" FontSize="13"
                        Click="BtnBrowse_Click"/>
                <TextBlock x:Name="lblFileName" Grid.Column="1" 
                           Text="Chưa chọn tệp nào (.pdf, .docx, .xlsx, .pptx, .txt, .md)" 
                           Style="{StaticResource HintTextBlockStyle}"
                           VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
            
        </StackPanel>

        <StackPanel Grid.Row="2" x:Name="spProgress" Visibility="Collapsed" Margin="0,0,0,15">
            <TextBlock Text="Đang xử lý tải lên..." Style="{StaticResource HintTextBlockStyle}" Margin="0,0,0,5"/>
            <ProgressBar x:Name="pbUpload" Style="{StaticResource ModernProgressBarStyle}" IsIndeterminate="True"/>
        </StackPanel>

        <UniformGrid Grid.Row="3" Columns="2" Rows="1" Height="38">
            <Button x:Name="btnUpload" Content="Tải Lên" Margin="0,0,10,0" Click="BtnUpload_Click"
                    Style="{StaticResource SuccessButtonStyle}"/>
            <Button x:Name="btnCancel" Content="Hủy Bỏ" Margin="10,0,0,0" Click="BtnCancel_Click"
                    Style="{StaticResource DangerButtonStyle}"/>
        </UniformGrid>
    </Grid>
</Window>
