<Window x:Class="Prn212.AIStudyHub.WPF.Views.UploadDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prn212.AIStudyHub.WPF.Views"
        mc:Ignorable="d"
        Title="Upload Tài Liệu Mới" Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Đăng Tải Tài Liệu Học Tập" 
                   FontSize="18" FontWeight="Bold" Foreground="#1E3A8A" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            
            <TextBlock Text="Tiêu đề tài liệu (*):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
            <TextBox x:Name="txtTitle" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,15"/>

            <TextBlock Text="Chọn môn học (*):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
            <ComboBox x:Name="cbSubject" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Người tải lên:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
            <TextBox x:Name="txtUserDisplayName" Height="30" VerticalContentAlignment="Center" Padding="5,0" 
                     Margin="0,0,0,15" IsReadOnly="True" Focusable="False" Background="#E5E7EB" BorderBrush="#D1D5DB"/>

            <TextBlock Text="Chọn tệp tin tài liệu (*):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnBrowse" Grid.Column="0" Content="Chọn tệp" 
                        Width="100" Height="30" Click="BtnBrowse_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock x:Name="lblFileName" Grid.Column="1" Text="Chưa chọn tệp nào (.pdf, .docx, .xlsx, .pptx, .txt, .md)" 
                           VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#6B7280" TextTrimming="CharacterEllipsis"/>
            </Grid>
            
        </StackPanel>

        <StackPanel Grid.Row="2" x:Name="spProgress" Visibility="Collapsed" Margin="0,0,0,15">
            <TextBlock Text="Đang xử lý tải lên..." FontSize="11" Foreground="#4B5563" Margin="0,0,0,5"/>
            <ProgressBar x:Name="pbUpload" Height="10" IsIndeterminate="True" Foreground="#10B981"/>
        </StackPanel>

        <UniformGrid Grid.Row="3" Columns="2" Rows="1" Height="35">
            <Button x:Name="btnUpload" Content="Tải Lên" Margin="0,0,10,0" Click="BtnUpload_Click"
                    Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="Hủy Bỏ" Margin="10,0,0,0" Click="BtnCancel_Click"
                    Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </UniformGrid>
    </Grid>
</Window>
